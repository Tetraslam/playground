# Global secret references for the playground.
#
# This file is COMMITTED TO GIT. It contains only 1Password secret
# *references* (op://...), never resolved values. The `op` CLI resolves
# them at runtime via tools/load-env.sh — nothing secret touches disk.
#
# Format:  VAR_NAME=op://<vault>/<item>/<field>
# Resolve: tools/load-env.sh -- <your command>
#
# Add per-toy overrides by dropping a `.env.op` in the toy's own directory;
# load-env.sh layers it on top of this one (per-path wins).

ANTHROPIC_API_KEY=op://Personal/ANTHROPIC_API_KEY/credential
OPENROUTER_API_KEY=op://Personal/OPENROUTER_API_KEY/credential
FIRECRAWL_API_KEY=op://Personal/FIRECRAWL_API_KEY/credential
MODAL_TOKEN_ID=op://Personal/MODAL_TOKEN_ID/credential
MODAL_TOKEN_SECRET=op://Personal/MODAL_TOKEN_SECRET/credential

# direnv config for the playground (optional — install direnv to use it).
#
# Activates the repo-root Python venv if present. Run `uv sync` first to
# create it. We deliberately do NOT auto-resolve secrets here (that would
# spawn 1Password prompts on every `cd`); instead, inject secrets explicitly
# per-command with tools/load-env.sh. See AGENTS.md.
[ -d .venv ] && source .venv/bin/activate

# Convenience: put repo tools on PATH so `load-env.sh` is callable bare.
PATH_add tools

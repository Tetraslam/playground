# Python
.venv/
__pycache__/
*.pyc
.ruff_cache/
.pytest_cache/
.mypy_cache/

# Node / pnpm
node_modules/
.pnpm-store/
dist/
*.tsbuildinfo

# Rust
target/

# Go
# (binaries built into toy dirs)
/toys/*/*.bin

# Env / secrets — NEVER commit resolved secrets.
# .env.op files (op:// references only) ARE committed; resolved .env are not.
.env
.env.local
.env.*.local
!.env.op
!*.env.op

# OS / editor
.DS_Store
*.swp
.idea/

# Screenshots / scratch outputs agents make while playing
/scratch/
*.tmp

# Playwright MCP run artifacts (snapshots/console logs from headless screenshots)
.playwright-mcp/

# Blender
*.blend1
*.blend2
/toys/*/renders/
*.exr
